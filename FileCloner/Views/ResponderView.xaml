<Window x:Class="FileCloner.Views.ResponderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileCloner.Views"
        mc:Ignorable="d"
        Title="Responder View" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="File Request Incoming!" FontSize="18" Margin="10" HorizontalAlignment="Center"/>
            <TextBlock Text="A user is requesting access to your files." FontSize="14" HorizontalAlignment="Center"/>

            <!-- Accept or Decline Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button Content="Accept" Command="{Binding AcceptCommand}" Width="100" Margin="5"/>
                <Button Content="Decline" Command="{Binding DeclineCommand}" Width="100" Margin="5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
