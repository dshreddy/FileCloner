.vs/
# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific folders
.vscode/
.vs/
_ReSharper*/
*/_ReSharper*/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Rider project files
.idea/

# Uncomment if you have tasks that create the project's static files and don't want to track them.
# [Pp]ublic/
# [Ss]tatic/
# [Pp]rivate/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# SQL Server files
*.mdf
*.ldf

# NuGet Packages
*.nupkg
**/packages/*
*.snupkg

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Additional files generated by macOS
.DS_Store
.AppleDouble
.LSOverride

# Folders created by macOS Finder for storing file tags
.Spotlight-V100
.Trashes

# Hidden file stored in repos
.DS_Store
.idea/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Optional: ignore test project files if not required
*.testresults
*.trx

# Optional: ignore generated documentation files if not required
*.generated.cs
*.generated.cpp
*.generated.h
*.generated.sql

# Optional: ignore third-party tool settings files
*.DotSettings.user

# End of file
